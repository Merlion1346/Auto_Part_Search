# 복사해서 .env 로 채우세요. .env 는 절대 커밋하지 마세요 (.gitignore 등록됨).

# --- Digi-Key (https://developer.digikey.com) ---
DIGIKEY_CLIENT_ID=
DIGIKEY_CLIENT_SECRET=
# 테스트는 샌드박스로: https://sandbox-api.digikey.com
DIGIKEY_BASE=https://api.digikey.com

# --- Mouser (https://www.mouser.com/api-hub) ---
MOUSER_API_KEY=
MOUSER_BASE=https://api.mouser.com

# --- 사양 추출용 LLM (OpenAI 호환 엔드포인트) ---
# Colab 데이터 수집 시: 노트북에서 Ollama를 띄우고(`ollama serve` + `ollama pull qwen3:14b`)
#   아래 기본값 그대로 사용.
# vLLM 예시:
#   LLM_BASE_URL=http://localhost:8000/v1
#   LLM_API_KEY=EMPTY
#   LLM_MODEL=Qwen/Qwen3-14B
# DashScope(Qwen 클라우드) 예시:
#   LLM_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
#   LLM_API_KEY=sk-xxxx
#   LLM_MODEL=qwen-plus
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=qwen3:14b

# --- 경로 (Colab: Google Drive 경로로 덮어쓰면 런타임 재시작에도 보존됨) ---
# 예) PDF_DIR=/content/drive/MyDrive/auto_search/datasheets
PDF_DIR=data/datasheets
CATALOG_PATH=data/parts_catalog.json
